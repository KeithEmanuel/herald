# Herald — environment variables
# Copy to .env and fill in before running.
# This file lives at HERALD_ROOT/.env alongside compose.yaml.

# Discord bot token — from https://discord.com/developers/applications
DISCORD_TOKEN=your-discord-bot-token-here

# Anthropic API key — passed through to Claude Code CLI in agent runs
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Your Discord user ID — restricts push approvals (👍/👎) to this user only.
# Right-click your username in Discord → Copy User ID (requires Developer Mode).
# If unset, any server member can approve pushes (not recommended).
HERALD_OPERATOR_ID=your-discord-user-id-here

# Absolute path to the Herald root directory on the host.
# This must be an absolute path — it's used as both sides of Docker volume mounts
# so that paths inside the container match the host (required for docker compose to
# resolve project compose file paths correctly).
#
# Layout under this directory:
#   repos/      — project source repos (including repos/herald — Herald itself)
#   deployments/ — project docker compose stacks
#   projects/   — private YAML configs (managed by Herald)
#
HERALD_ROOT=/srv/herald

# Container runtime socket path on the host.
# Docker (default): /var/run/docker.sock
# Podman rootless:  /run/user/<uid>/podman/podman.sock
#   Find your UID with: id -u
#   Requires podman system service running as the herald user (see docs/spec.md)
# The socket is always mounted at /var/run/docker.sock inside the Herald container.
# HERALD_DOCKER_SOCKET=/run/user/1000/podman/podman.sock

# Optional: override the Claude CLI executable path (default: claude)
# Useful if claude is not on PATH in the Docker image.
# HERALD_CLAUDE_BIN=claude

# Optional: default timeout for a single agent run, in seconds (default: 600)
# HERALD_AGENT_TIMEOUT=600
