# Herald — environment variables
# Copy to .env and fill in before running.
# On the server, these live in docker/herald/.env

# Discord bot token — from https://discord.com/developers/applications
DISCORD_TOKEN=your-discord-bot-token-here

# Anthropic API key — passed through to Claude Code CLI in agent runs
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Your Discord user ID — restricts push approvals (👍/👎) to this user only.
# Right-click your username in Discord → Copy User ID (requires Developer Mode).
# If unset, any server member can approve pushes (not recommended).
HERALD_OPERATOR_ID=your-discord-user-id-here

# Directory containing all your project repos.
# Mounted into Herald at the same absolute path (required — see compose.yaml).
# All projects registered via !addproject must live under this root.
HERALD_REPOS_ROOT=/srv/repos

# Directory for project deployment compose stacks.
# Also mounted at the same absolute path inside the container.
# Each project gets: $HERALD_DEPLOYMENTS_DIR/<projectname>/compose.yaml
HERALD_DEPLOYMENTS_DIR=/srv/herald/deployments

# Path to the projects/ directory containing *.yaml config files.
# Default: ./projects (alongside compose.yaml on the host)
HERALD_PROJECTS_DIR=./projects

# Optional: override the Claude CLI executable path (default: claude)
# Useful if claude is not on PATH in the Docker image.
# HERALD_CLAUDE_BIN=claude

# Optional: default timeout for a single agent run, in seconds (default: 600)
# HERALD_AGENT_TIMEOUT=600
