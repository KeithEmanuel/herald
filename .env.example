# Herald — environment variables
# Copy to .env and fill in before running.
# On the server, these live in docker/herald/.env

# Discord bot token — from https://discord.com/developers/applications
DISCORD_TOKEN=your-discord-bot-token-here

# Anthropic API key — passed through to Claude Code CLI in agent runs
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Path to the projects/ directory containing *.yaml config files.
# When running via Docker, this is bind-mounted in.
# Default: ./projects (relative to the herald package root)
HERALD_PROJECTS_DIR=./projects

# Optional: override the Claude CLI executable path (default: claude)
# Useful if claude is not on PATH in the Docker image.
# HERALD_CLAUDE_BIN=claude

# Optional: default timeout for a single agent run, in seconds (default: 600)
# HERALD_AGENT_TIMEOUT=600
