# Private project configs — contain server paths, Discord channel IDs, etc.
# Keep example.yaml in source control; exclude everything else.
projects/*.yaml
!projects/example.yaml

# Environment variables
.env

# Python
__pycache__/
*.py[cod]
*.egg-info/
dist/
build/
.venv/
venv/

# Data directory — activity logs, etc. (runtime state, not source)
data/

# Contributor profiles — private, per-developer context for the agent.
# .herald/humans/* ignores the contents but allows file-level exceptions (unlike dir/ which blocks all).
# keith.md is tracked in Herald's repo because it gets copied to new project repos at !addproject time.
.herald/humans/*
!.herald/humans/keith.md

# Claude Code local session state (permissions, tool approvals)
.claude/
